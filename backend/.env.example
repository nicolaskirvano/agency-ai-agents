# LLM Provider (glm5, openai, anthropic)
LLM_PROVIDER=glm5

# GLM-5 (Zhipu AI) - Default
GLM_API_KEY=your-zhipu-api-key
GLM_BASE_URL=https://api.z.ai/api/paas/v4/
GLM_MODEL=glm-5

# OpenAI (alternativa)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic (alternativa)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Integrações
META_ADS_ACCESS_TOKEN=your-meta-ads-token
META_ADS_ACCOUNT_ID=act_your_account_id
CANVA_API_KEY=your-canva-key
